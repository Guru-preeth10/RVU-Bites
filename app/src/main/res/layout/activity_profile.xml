<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="My Profile"
            app:titleTextColor="@color/text_title" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="130dp"
                android:layout_height="130dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="65dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp">
                    <ImageView
                        android:id="@+id/ivProfileLarge"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_myplaces" />
                </com.google.android.material.card.MaterialCardView>
                
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabEditImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/ic_menu_camera"
                    app:fabCustomSize="36dp"
                    app:tint="@color/white" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="John Doe"
                android:textColor="@color/text_title"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="john.doe@rvu.edu.in"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditProfile"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Edit Profile"
                        android:textColor="@color/text_title"
                        app:icon="@android:drawable/ic_menu_edit"
                        app:iconPadding="16dp"
                        app:iconTint="@color/primary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/divider" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSavedAddresses"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="My Addresses"
                        android:textColor="@color/text_title"
                        app:icon="@android:drawable/ic_menu_directions"
                        app:iconPadding="16dp"
                        app:iconTint="@color/primary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/divider" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOrders"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Order History"
                        android:textColor="@color/text_title"
                        app:icon="@android:drawable/ic_menu_recent_history"
                        app:iconPadding="16dp"
                        app:iconTint="@color/primary" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/divider" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAbout"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="About App"
                        android:textColor="@color/text_title"
                        app:icon="@android:drawable/ic_menu_info_details"
                        app:iconPadding="16dp"
                        app:iconTint="@color/primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Logout"
                android:textColor="@color/error"
                app:backgroundTint="#1AE53935"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/error" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Version 1.0.0"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>